# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Transaction pooler (port 6543) connection string for serverless server-side access
DATABASE_URL=

# Usage-event IP hashing
USAGE_EVENTS_IP_SALT=

# AI providers (Phase 2 — free tiers only)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# Precompute cron auth (Phase 2) — Vercel automatically sends this as a Bearer token to
# vercel.json's scheduled routes once it's set as a project env var.
CRON_SECRET=
